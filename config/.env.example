# =============================================================================
# ThirdLine — Environment Configuration
# =============================================================================
#
# WHAT THIS FILE DOES:
#   Defines all environment variables required to run ThirdLine.
#   Copy this file to config/.env and fill in your values.
#   Never commit config/.env to git — it is in .gitignore.
#
# HOW TO USE:
#   cp config/.env.example config/.env
#   # Then open config/.env in your editor and fill in values
#
# SECTIONS:
#   [1] GCP Project
#   [2] GCP Services
#   [3] AI / LLM APIs
#   [4] Application
#   [5] Local development
# =============================================================================

# ── [1] GCP Project ──────────────────────────────────────────────────────────
GCP_PROJECT_ID=your-gcp-project-id          # e.g. thirdline-audit-dev
GCP_REGION=us-central1                       # Primary region
GCP_ZONE=us-central1-a                       # Primary zone

# ── [2] GCP Services ─────────────────────────────────────────────────────────
# BigQuery
BIGQUERY_DATASET=thirdline                   # Dataset name in BigQuery
BIGQUERY_LOCATION=US                         # Dataset location

# Cloud Storage
GCS_BUCKET_RAW=thirdline-raw-telemetry       # Raw telemetry landing bucket
GCS_BUCKET_ARTIFACTS=thirdline-artifacts     # Pipeline artifacts bucket

# Pub/Sub
PUBSUB_TOPIC_TELEMETRY=thirdline-agent-telemetry
PUBSUB_SUBSCRIPTION_TELEMETRY=thirdline-agent-telemetry-sub

# Cloud Run
CLOUD_RUN_SERVICE_API=thirdline-api
CLOUD_RUN_REGION=us-central1

# Vertex AI
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_INDEX_ENDPOINT=                    # Fill after terraform apply
VERTEX_AI_INDEX_ID=                          # Fill after terraform apply

# ── [3] AI / LLM APIs ────────────────────────────────────────────────────────
# Gemini (primary LLM — get from Google AI Studio: aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash                # Cost-effective for high-volume eval
GEMINI_MODEL_JUDGE=gemini-1.5-pro            # Higher quality for LLM-as-judge

# Anthropic / Claude (optional fallback LLM)
ANTHROPIC_API_KEY=your-anthropic-api-key
CLAUDE_MODEL=claude-sonnet-4-6

# LangSmith tracing (optional — set LANGCHAIN_TRACING_V2=false to disable)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your-langsmith-api-key
LANGCHAIN_PROJECT=thirdline

# ── [4] Application ───────────────────────────────────────────────────────────
# API security
API_SECRET_KEY=change-this-to-a-random-32-char-string
API_ALGORITHM=HS256
API_TOKEN_EXPIRE_MINUTES=480                 # 8-hour sessions

# RBAC roles (do not change — used in code)
ROLE_AUDITOR=auditor
ROLE_VALIDATOR=validator
ROLE_AGENT_OWNER=agent_owner
ROLE_LEADERSHIP=leadership

# Application
APP_ENV=development                          # development | staging | production
APP_LOG_LEVEL=INFO
APP_VERSION=1.0.0

# ── [5] Local development ─────────────────────────────────────────────────────
# Use LOCAL_MODE=true to skip GCP calls and use local ChromaDB / SQLite
LOCAL_MODE=true                              # Set false when GCP is provisioned

# Local ChromaDB (for MVP RAG — replaces Vertex AI Vector Search)
CHROMA_PERSIST_PATH=.artifacts/chromadb

# Number of synthetic interactions to generate per agent
SYNTHETIC_INTERACTIONS_PER_AGENT=50

# Defect injection flags (set to false to test a clean fleet)
INJECT_HALLUCINATION=true
INJECT_BIAS=true
INJECT_DRIFT=true
INJECT_ROBUSTNESS=true
INJECT_RELIABILITY=true

# Drift simulation: interactions after this index will show drift
DRIFT_START_INDEX=30

# Evaluation thresholds
HALLUCINATION_PASS_THRESHOLD=0.75           # Faithfulness score >= this = pass
BIAS_DISPARATE_IMPACT_THRESHOLD=0.80        # Ratio >= this = pass
DRIFT_PSI_THRESHOLD=0.20                    # PSI < this = pass (no drift)
RELIABILITY_PASS_THRESHOLD=0.80             # Tool accuracy >= this = pass

# Audit ledger
AUDIT_LEDGER_HASH_ALGORITHM=sha256

# ── END ───────────────────────────────────────────────────────────────────────
